f05f0c","deletedAt":1780917494438},{"id":"2e8fffeb-1ba6-42c8-a620-0f9bab25dd63","type":"mindMapCard","item":{"id":"4b61603d-f954-4819-898d-82cf07a59dd3","title":"常佑扭了扭身体，从李返真的手里边挣脱出来，平稳而潇洒地落地。","content":"常佑扭了扭身体，从李返真的手里边挣脱出来，平稳而潇洒地落地。","parentId":null,"children":[],"createdAt":1780917485610},"bookId":"3ef2c972-dba1-4872-8b43-3b40b0f05f0c","deletedAt":1780917494438},{"id":"1e313833-0fa6-4237-8e3d-c8ee4861ea23","type":"mindMapCard","item":{"id":"ba43869a-5ff6-41ac-bbed-d511dafcf28b","title":"“对！你们这有谁想和我打一架吗？”","content":"“对！你们这有谁想和我打一架吗？”","parentId":null,"children":[],"createdAt":1780917485610},"bookId":"3ef2c972-dba1-4872-8b43-3b40b0f05f0c","deletedAt":1780917494438},{"id":"10b5709d-d50a-4ac6-8f40-d41298f0dec0","type":"mindMapCard","item":{"id":"6f1a2c57-3073-4d33-95ea-88ce1bf4373c","title":"一阵白光闪过，面前的犬妖化身为人，一把比她自个还长的大刀插在","content":"一阵白光闪过，面前的犬妖化身为人，一把比她自个还长的大刀插在地上，刀尖穿入地面。常佑穿了件棕色外袍，搭着白色内杉，肉眼可见袖子边角处的磨损。这朴素的气质，一点不像所谓的神仙。","parentId":null,"children":[],"createdAt":1780917485610},"bookId":"3ef2c972-dba1-4872-8b43-3b40b0f05f0c","deletedAt":1780917494439},{"id":"8131d37d-14c9-4501-8064-c09bb0f21292","type":"mindMapCard","item":{"id":"d903024b-b86b-4a88-bbc9-59f5eb078980","title":"“打架？天火都掉下来了，谁有这个心情和你打架？”林九霄嚷嚷着","content":"“打架？天火都掉下来了，谁有这个心情和你打架？”林九霄嚷嚷着。","parentId":null,"children":[],"createdAt":1780917485611},"bookId":"3ef2c972-dba1-4872-8b43-3b40b0f05f0c","deletedAt":1780917494439},{"id":"ef7f3d5f-c283-4ec3-812f-fc047a51ebeb","type":"mindMapCard","item":{"id":"1a241a70-6b1b-42d4-9df5-be7d58a86939","title":"“你既然是仙，为何毫无担当，不替黎民百姓想想？”缘不名也颇有","content":"“你既然是仙，为何毫无担当，不替黎民百姓想想？”缘不名也颇有微词。","parentId":null,"children":[],"createdAt":1780917485611},"bookId":"3ef2c972-dba1-4872-8b43-3b40b0f05f0c","deletedAt":1780917494440},{"id":"be460900-c2ac-43c8-8303-bace7ff35797","type":"mindMapCard","item":{"id":"c274dab1-6920-49f1-82b5-753998c2dd0a","title":"常佑：“你们不是想知道天火为何坠地吗？我知道。你们这里要是有","content":"常佑：“你们不是想知道天火为何坠地吗？我知道。你们这里要是有谁能过得了我一招的，我就把我知道的都和你们说了。”","parentId":null,"children":[],"createdAt":1780917485611},"bookId":"3ef2c972-dba1-4872-8b43-3b40b0f05f0c","deletedAt":1780917494440},{"id":"21b29532-affc-4219-a9fa-911295061e05","type":"mindMapCard","item":{"id":"66ada922-3021-43d6-b838-d73f34a8e8b5","title":"李继捂住脸，叹了口气，想着这次大概是不得不去了。林九霄咳嗽一","content":"李继捂住脸，叹了口气，想着这次大概是不得不去了。林九霄咳嗽一声，看向别处。缘不名则用胳膊肘捅了捅缘舜，有意使坏。缘舜毅然起身：“我来。”","parentId":null,"children":[],"createdAt":1780917485611},"bookId":"3ef2c972-dba1-4872-8b43-3b40b0f05f0c","deletedAt":1780917494441},{"id":"d6f5e787-b6dc-48c9-9e06-05e72b308860","type":"mindMapCard","item":{"id":"53f8e08e-fac0-4aa1-91bc-4fa3eeb2b8c3","title":"缘舜来到常佑面前，向她行礼：“敢问阁下姓名？”","content":"缘舜来到常佑面前，向她行礼：“敢问阁下姓名？”","parentId":null,"children":[],"createdAt":1780917485611},"bookId":"3ef2c972-dba1-4872-8b43-3b40b0f05f0c","deletedAt":1780917494441},{"id":"e398851c-2b25-462d-b048-4cbed29881f8","type":"mindMapCard","item":{"id":"7a600131-cffc-473d-9876-7cce799629c7","title":"“常佑。平常的常，保佑的佑。”","content":"“常佑。平常的常，保佑的佑。”","parentId":null,"children":[],"createdAt":1780917485611},"bookId":"3ef2c972-dba1-4872-8b43-3b40b0f05f0c","deletedAt":1780917494441},{"id":"c3849365-d31f-4c14-aa83-6dfea209a86d","type":"mindMapCard","item":{"id":"024bb35e-1842-46cb-b25b-18f30ed503b2","title":"“常仙师，请。”","content":"“常仙师，请。”","parentId":null,"children":[],"createdAt":1780917485611},"bookId":"3ef2c972-dba1-4872-8b43-3b40b0f05f0c","deletedAt":1780917494442},{"id":"c0ebb88b-e809-47c4-a45f-89cf4c003018","type":"mindMapCard","item":{"id":"b0a5eaf4-b69e-4106-a612-b013b59a9943","title":"常佑有些惊讶。哟，她又看了看上边的人，一点动静都无，真让这个","content":"常佑有些惊讶。哟，她又看了看上边的人，一点动静都无，真让这个人来？难道说，他们真心觉得这人就是最强的？不对呀，按她来看，论灵力的深厚，那个叫李继的最强，不比自己差。","parentId":null,"children":[],"createdAt":1780917485611},"bookId":"3ef2c972-dba1-4872-8b43-3b40b0f05f0c","deletedAt":1780917494442},{"id":"c17c4e2e-395d-4eda-a440-3a0ad086ec3c","type":"mindMapCard","item":{"id":"8abc0cbf-d0bf-4f79-9500-4ed27685c9fd","title":"算了算了，不管他们怎么想的，反正，她要打架！","content":"算了算了，不管他们怎么想的，反正，她要打架！","parentId":null,"children":[],"createdAt":1780917485611},"bookId":"3ef2c972-dba1-4872-8b43-3b40b0f05f0c","deletedAt":1780917494443},{"id":"80d4ec84-7864-4506-8967-ff4d0da60420","type":"mindMapCard","item":{"id":"e969a6f1-0d68-4a68-b620-86ca8622dd87","title":"\"那你先出手，我不欺负你。\"","content":"\"那你先出手，我不欺负你。\"","parentId":null,"children":[],"createdAt":1780917485611},"bookId":"3ef2c972-dba1-4872-8b43-3b40b0f05f0c","deletedAt":1780917494443},{"id":"f54b1012-81ac-4267-b69b-eefede979957","type":"mindMapCard","item":{"id":"a48d3199-97e3-42c2-828f-598778f005c4","title":"常佑扬扬下巴，示意缘舜。","content":"常佑扬扬下巴，示意缘舜。","parentId":null,"children":[],"createdAt":1780917485611},"bookId":"3ef2c972-dba1-4872-8b43-3b40b0f05f0c","deletedAt":1780917494444},{"id":"41ce4962-6f09-4e3d-ae65-32fc2ef9d217","type":"mindMapCard","item":{"id":"b8ea8ee1-1651-4a8a-ac27-a2ffe427933c","title":"缘不名看看李继，嘴角勾着笑，他又看看缘舜，摇了摇头。李继皱眉","content":"缘不名看看李继，嘴角勾着笑，他又看看缘舜，摇了摇头。李继皱眉，缘舜这武痴，就是执念太深，对武之一字钻研到极致，反过来忘了修仙者所需的心志，是要钻的进去，跳的出来。哎，可他太痴，放不开啊。还有这缘不名，也是个坏种，他知道他哥什么脾气，这就是故意的。","parentId":null,"children":[],"createdAt":1780917485611},"bookId":"3ef2c972-dba1-4872-8b43-3b40b0f05f0c","deletedAt":1780917494444},{"id":"bf35491e-2a88-446d-92f5-a7fc0b2d0090","type":"mindMapCard","item":{"id":"2776b526-ee5d-4e39-8f9e-533300f3e585","title":"林九霄没什么表情，自顾自倒了杯茶，看向台下：“我看他今天要栽","content":"林九霄没什么表情，自顾自倒了杯茶，看向台下：“我看他今天要栽。”","parentId":null,"children":[],"createdAt":1780917485611},"bookId":"3ef2c972-dba1-4872-8b43-3b40b0f05f0c","deletedAt":1780917494444},{"id":"7da40658-6e0e-4592-91be-2017624b179d","type":"mindMapCard","item":{"id":"698800e6-96bd-4d50-bd39-253522eaae50","title":"“我哥要输也会打的。”","content":"“我哥要输也会打的。”","parentId":null,"children":[],"createdAt":1780917485611},"bookId":"3ef2c972-dba1-4872-8b43-3b40b0f05f0c","deletedAt":1780917494445},{"id":"43e762e3-0312-4f78-9217-dbdd00609ce7","type":"mindMapCard","item":{"id":"9c27aeb4-04a1-4b6b-86d1-4b30918fdfe8","title":"缘不名这句话欠欠的，也没藏着，下边的人都听得见。","content":"缘不名这句话欠欠的，也没藏着，下边的人都听得见。","parentId":null,"children":[],"createdAt":1780917485611},"bookId":"3ef2c972-dba1-4872-8b43-3b40b0f05f0c","deletedAt":1780917494445},{"id":"249ee720-1fe0-4d08-8252-09fad38e1b3e","type":"mindMapCard","item":{"id":"532c50e0-22d6-438c-b2f8-1426b21f4f46","title":"缘舜唤出自己的长枪，摆好架势，大喝一声，便朝着常佑冲了过去。","content":"缘舜唤出自己的长枪，摆好架势，大喝一声，便朝着常佑冲了过去。长枪随着他手中动作，迅速刺出，眼看着就要穿透常佑的腰腹。这一招大开大合，破绽极多，然而他断定常佑若要挥舞这样的长刀，就不可能兼具灵活，这一招，是险招，要一次决出个胜负来！","parentId":null,"children":[],"createdAt":1780917485611},"bookId":"3ef2c972-dba1-4872-8b43-3b40b0f05f0c","deletedAt":1780917494445},{"id":"7d130f20-77b7-4073-ac78-08398841b771","type":"mindMapCard","item":{"id":"1ac155a8-dd16-4f16-8ada-bb2d56023f31","title":"常佑没有选择正面接下，而是轻盈地跃到半空，把刀拔了出来，而后","content":"常佑没有选择正面接下，而是轻盈地跃到半空，把刀拔了出来，而后像杂耍一般，脚尖点了点枪身，借力跳到缘舜肩上，最后用刀背，轻轻勾住了男人的脖子。","parentId":null,"children":[],"createdAt":1780917485611},"bookId":"3ef2c972-dba1-4872-8b43-3b40b0f05f0c","deletedAt":1780917494446},{"id":"2662c378-c630-4331-897b-d8219b856730","type":"mindMapCard","item":{"id":"b37cf465-fade-4b03-a9ac-1b50965932eb","title":"“现在你已经死了一次。”","content":"“现在你已经死了一次。”","parentId":null,"children":[],"createdAt":1780917485611},"bookId":"3ef2c972-dba1-4872-8b43-3b40b0f05f0c","deletedAt":1780917494446},{"id":"19c55d9e-4bf8-44cd-9d51-99612f750b05","type":"mindMapCard","item":{"id":"112fb0b4-d5ae-4dc6-bafb-f700aa8bfaf7","title":"常佑笑道：“再来?”","content":"常佑笑道：“再来?”","parentId":null,"children":[],"createdAt":1780917485611},"bookId":"3ef2c972-dba1-4872-8b43-3b40b0f05f0c","deletedAt":1780917494447},{"id":"a023e499-9277-41c2-8965-d1d6413e9de8","type":"mindMapCard","item":{"id":"8a1ef936-7726-4fc1-8d87-5de959b7b215","title":"她看出缘舜心急，刻意要给他个下马威。","content":"她看出缘舜心急，刻意要给他个下马威。","parentId":null,"children":[],"createdAt":1780917485611},"bookId":"3ef2c972-dba1-4872-8b43-3b40b0f05f0c","deletedAt":1780917494447},{"id":"1b4efedf-fbf1-45d6-85dd-926431915bd0","type":"mindMapCard","item":{"id":"875af549-1ac5-4d83-a51d-5dc28be721db","title":"缘舜：“再来！”","content":"缘舜：“再来！”","parentId":null,"children":[],"createdAt":1780917485611},"bookId":"3ef2c972-dba1-4872-8b43-3b40b0f05f0c","deletedAt":1780917494448},{"id":"e7d4b3bf-91e4-4614-a3a6-262cc6d63bd5","type":"mindMapCard","item":{"id":"8f4e18c0-0ebe-450c-8c6a-a1ab82b71733","title":"他将身形再次下压，把长枪往常佑的方向又一次刺出，这次枪尖不停","content":"他将身形再次下压，把长枪往常佑的方向又一次刺出，这次枪尖不停抖动，叫人看不清究竟是往哪攻。若想要防守，每一个落点都十分致命，不可能个个守住，若想要反攻，又不得不忌惮于这样激进的攻势。","parentId":null,"children":[],"createdAt":1780917485611},"bookId":"3ef2c972-dba1-4872-8b43-3b40b0f05f0c","deletedAt":1780917494448},{"id":"8484de8e-d484-412a-9e46-759204ee70a2","type":"mindMapCard","item":{"id":"dbb4322c-14e9-47a5-a01c-0a4dbfd73ace","title":"常佑哈哈大笑，这人枪玩的不错，可是太封闭了，像活在自己的世界","content":"常佑哈哈大笑，这人枪玩的不错，可是太封闭了，像活在自己的世界里一般，大概是那种埋头苦练，不和人交流，认为自己对武的理解天下第一高的。","parentId":null,"children":[],"createdAt":1780917485611},"bookId":"3ef2c972-dba1-4872-8b43-3b40b0f05f0c","deletedAt":1780917494448},{"id":"df001a75-64cb-460b-8bf5-7558ae424450","type":"mindMapCard","item":{"id":"3f2e3000-1379-448f-8571-26816491a1e2","title":"要打架，出手之前当然要先想想对方会怎么出招，可这人呢?看见自","content":"要打架，出手之前当然要先想想对方会怎么出招，可这人呢?看见自己是长刀就“我以为长刀沉重……”，吃瘪之后还在“我以为对方肯定会陷入两难境地”，真是太笨了，根本无视敌人和自己之间的差距。","parentId":null,"children":[],"createdAt":1780917485611},"bookId":"3ef2c972-dba1-4872-8b43-3b40b0f05f0c","deletedAt":1780917494449},{"id":"9ae223ea-ffe7-4f90-9207-b59c2442d7a6","type":"mindMapCard","item":{"id":"896143d0-9775-4a31-bad1-8cd0c59164a5","title":"高对低有一套打法，低对高也有一套打法，可这人打法，乃是对着他","content":"高对低有一套打法，低对高也有一套打法，可这人打法，乃是对着他自己研究出来的——他读的也是自己的心。","parentId":null,"children":[],"createdAt":1780917485611},"bookId":"3ef2c972-dba1-4872-8b43-3b40b0f05f0c","deletedAt":1780917494449},{"id":"fa4f39ca-33d5-421d-a4c4-6abacc2efbf5","type":"mindMapCard","item":{"id":"a4963bed-244b-4c73-858b-f80e7012d51a","title":"世间武功有千百种变换，习武之人怎会不懂，以武会友乃是以武见心","content":"世间武功有千百种变换，习武之人怎会不懂，以武会友乃是以武见心，他成天对着自己的一颗心琢磨，不入魔才怪呢！这么简单的道理，常佑不信这人已经学到这般地步了还会不懂，那他可真是白活了这么多岁。唯一的解释就是，他故意的。","parentId":null,"children":[],"createdAt":1780917485611},"bookId":"3ef2c972-dba1-4872-8b43-3b40b0f05f0c","deletedAt":1780917494450},{"id":"f4cb66d8-e4a8-41f7-be70-2cf9713a2854","type":"mindMapCard","item":{"id":"469e6216-4a54-4e19-8b2b-870d729d4ce6","title":"哼，你不尊重你自己，也别怪我不尊重你了！","content":"哼，你不尊重你自己，也别怪我不尊重你了！","parentId":null,"children":[],"createdAt":1780917485611},"bookId":"3ef2c972-dba1-4872-8b43-3b40b0f05f0c","deletedAt":1780917494450},{"id":"a4797649-f3ba-4725-be76-85a3d004805e","type":"mindMapCard","item":{"id":"68ea5acc-1b7d-4c5d-9181-933bb1dcda00","title":"她没有退，而是当着缘舜的面，出了一指。这一指对上枪尖，两股能","content":"她没有退，而是当着缘舜的面，出了一指。这一指对上枪尖，两股能量对冲，二人都停住。一旁李返真震撼不已，他根本没来得及看清二人动作，只听得“砰砰”两声，那由林九霄亲自铸成的贯云枪已经断成六截，落在地上。","parentId":null,"children":[],"createdAt":1780917485611},"bookId":"3ef2c972-dba1-4872-8b43-3b40b0f05f0c","deletedAt":1780917494451},{"id":"57cbd1fb-4f0b-46ec-bf00-fa65be703382","type":"mindMapCard","item":{"id":"f3056939-83b5-4be4-8d58-74473f087169","title":"“你想逼我出刀，可你实力不够。你的灵力根本撑不起你的武术，你","content":"“你想逼我出刀，可你实力不够。你的灵力根本撑不起你的武术，你的身体比你的脑子更快。你赢不了我。”","parentId":null,"children":[],"createdAt":1780917485611},"bookId":"3ef2c972-dba1-4872-8b43-3b40b0f05f0c","deletedAt":1780917494452},{"id":"43145c5f-c562-4ad8-8963-b9cf3cdcea27","type":"mindMapCard","item":{"id":"d89b5c55-ddc0-4d46-b24c-f94261696ad5","title":"常佑说完，扭头看向上方：“还有谁要来？”","content":"常佑说完，扭头看向上方：“还有谁要来？”","parentId":null,"children":[],"createdAt":1780917485611},"bookId":"3ef2c972-dba1-4872-8b43-3b40b0f05f0c","deletedAt":1780917494452},{"id":"b10b4821-1b55-4da1-92d6-e1f5b5103272","type":"mindMapCard","item":{"id":"bf9a4dce-5125-4e73-8cdc-3125e7306542","title":"李继已经站起身了，而缘舜还不死心。他双手握拳，再次架好起手式","content":"李继已经站起身了，而缘舜还不死心。他双手握拳，再次架好起手式。","parentId":null,"children":[],"createdAt":1780917485612},"bookId":"3ef2c972-dba1-4872-8b43-3b40b0f05f0c","deletedAt":1780917494452},{"id":"c1a6c7ab-5977-41b7-aad3-10b57da892e1","type":"mindMapCard","item":{"id":"3bd9ed6a-7e3a-4f8e-a81c-7be3689a0dda","title":"“请常仙师，再指点我一二！”","content":"“请常仙师，再指点我一二！”","parentId":null,"children":[],"createdAt":1780917485612},"bookId":"3ef2c972-dba1-4872-8b43-3b40b0f05f0c","deletedAt":1780917494453},{"id":"9d77440c-27f6-4ea6-bffe-0aa1bb80daed","type":"mindMapCard","item":{"id":"a0dbcd93-5e97-416f-b26a-08887fecc319","title":"“缘舜，点到为止，我来吧。常仙师，叫您见笑，我这朋友沉迷武道","content":"“缘舜，点到为止，我来吧。常仙师，叫您见笑，我这朋友沉迷武道，有一回为了那几招失传的技艺，把整个藏书库都啃下来了，没日没夜的找。他对于武之一道，的确真心。您就少说两句吧。”","parentId":null,"children":[],"createdAt":1780917485612},"bookId":"3ef2c972-dba1-4872-8b43-3b40b0f05f0c","deletedAt":1780917494453},{"id":"da559646-b14e-46a0-a59b-b6ec06aee3dd","type":"mindMapCard","item":{"id":"3bd386a0-d767-4dfc-ad9e-deb7fd7ca392","title":"李继看不下去了，试图救场。","content":"李继看不下去了，试图救场。","parentId":null,"children":[],"createdAt":1780917485612},"bookId":"3ef2c972-dba1-4872-8b43-3b40b0f05f0c","deletedAt":1780917494453},{"id":"947f4943-fbdf-441d-9a89-27fee0a65c88","type":"mindMapCard","item":{"id":"c70f9d8e-b4d1-4ac1-bd76-fb572bf2e3a8","title":"常佑：“学武先学做人呀，他师父没教吗?”","content":"常佑：“学武先学做人呀，他师父没教吗?”","parentId":null,"children":[],"createdAt":1780917485612},"bookId":"3ef2c972-dba1-4872-8b43-3b40b0f05f0c","deletedAt":1780917494454},{"id":"f6cf4f6d-919d-4b3f-a85b-d04191f474b1","type":"mindMapCard","item":{"id":"1f932ca9-a20a-41cb-a26a-eb2e29b10c1f","title":"听完这话，缘不名也站起来了：“你骂谁呢?啊?”","content":"听完这话，缘不名也站起来了：“你骂谁呢?啊?”","parentId":null,"children":[],"createdAt":1780917485612},"bookId":"3ef2c972-dba1-4872-8b43-3b40b0f05f0c","deletedAt":1780917494454},{"id":"9d3d33ae-df39-4a90-a9bf-2cb873dc5c6b","type":"mindMapCard","item":{"id":"3aee1ce7-fc9b-45be-a086-7ad37fe57b11","title":"“我没骂人啊，以武入道，以志修仙，既然要成仙，当然是一手学武","content":"“我没骂人啊，以武入道，以志修仙，既然要成仙，当然是一手学武，一手修心，既然你只想闷头练武，干嘛不回凡间去，白白浪费这里的灵气。”","parentId":null,"children":[],"createdAt":1780917485612},"bookId":"3ef2c972-dba1-4872-8b43-3b40b0f05f0c","deletedAt":1780917494455},{"id":"9a6ed7d5-212f-4abc-a039-4f321ca4fcdb","type":"mindMapCard","item":{"id":"a514a25f-e76e-456f-976a-6ce4c3279faa","title":"“还有，我也还没成仙呢。我说我是天上下来的，可我并不是什么仙","content":"“还有，我也还没成仙呢。我说我是天上下来的，可我并不是什么仙师。”","parentId":null,"children":[],"createdAt":1780917485612},"bookId":"3ef2c972-dba1-4872-8b43-3b40b0f05f0c","deletedAt":1780917494455},{"id":"b4d228a8-3940-4ed0-807b-ca2a02d9825a","type":"mindMapCard","item":{"id":"9baeb85d-1534-4e58-85c5-01051342e4fe","title":"常佑抱着手臂：“我没有故意给你们出难题，只是若你们的决心弱到","content":"常佑抱着手臂：“我没有故意给你们出难题，只是若你们的决心弱到连我这一招都过不去，天火的事情还是我自个想办法吧。”","parentId":null,"children":[],"createdAt":1780917485612},"bookId":"3ef2c972-dba1-4872-8b43-3b40b0f05f0c","deletedAt":1780917494455},{"id":"856f7675-5d39-44ba-a541-2d0d8daca583","type":"mindMapCard","item":{"id":"8a0b9086-01b1-45da-8bcb-5f9659775dd9","title":"林九霄将已经空了的茶杯放下：“说得真好啊。呐，缘舜啊，你还是","content":"林九霄将已经空了的茶杯放下：“说得真好啊。呐，缘舜啊，你还是回来喝茶吧，人家愿意指点你一招两式是看得起你，你再要，过分了。”","parentId":null,"children":[],"createdAt":1780917485612},"bookId":"3ef2c972-dba1-4872-8b43-3b40b0f05f0c","deletedAt":1780917494456},{"id":"102f85f7-d77f-4a41-aaf1-737613a7fbe0","type":"mindMapCard","item":{"id":"b4060ce1-e6c6-46fe-89ee-cf5583e4a6d4","title":"被接二连三的刺激后，缘舜终于是吞不下这口气。他双手握拳，毫无","content":"被接二连三的刺激后，缘舜终于是吞不下这口气。他双手握拳，毫无征兆地朝常佑攻去，此刻常佑身后根本没有设防，可以说，缘舜是在偷袭了。缘不名“哎”了一声，却不是因为预见了常佑即将受伤，而是因为李继动了。","parentId":null,"children":[],"createdAt":1780917485612},"bookId":"3ef2c972-dba1-4872-8b43-3b40b0f05f0c","deletedAt":1780917494456},{"id":"35fc0acb-cee8-4029-af41-15796a1fb2c4","type":"mindMapCard","item":{"id":"a2ca4323-1858-461e-9aba-f291c926d888","title":"漫天剑光倾泄而下，常佑和缘舜都被覆盖其中。","content":"漫天剑光倾泄而下，常佑和缘舜都被覆盖其中。","parentId":null,"children":[],"createdAt":1780917485612},"bookId":"3ef2c972-dba1-4872-8b43-3b40b0f05f0c","deletedAt":1780917494456},{"id":"2744745d-8b40-43b3-a530-e9366d57b03b","type":"mindMapCard","item":{"id":"42c8131b-da62-4780-a1cf-8f79c82b163d","title":"李返真大喊：“师父！”","content":"李返真大喊：“师父！”","parentId":null,"children":[],"createdAt":1780917485612},"bookId":"3ef2c972-dba1-4872-8b43-3b40b0f05f0c","deletedAt":1780917494457},{"id":"3b49e8cd-f028-4737-a657-a2daa9952534","type":"mindMapCard","item":{"id":"49625cfa-2c7f-40b4-afed-ba2c63072e44","title":"他没看清，他没能看清，他的境界不足，看不出来那剑光究竟是朝谁","content":"他没看清，他没能看清，他的境界不足，看不出来那剑光究竟是朝谁而去。缘不名抓着李返真的后领，像拎小鸡一样将他拽到自己身后。下一刻，惊人的威压从中心爆发，连林九霄也没能稳住身形，倒在地上。个挨千刀的，他腹诽，李继明明能只对着缘舜放这玩意，这人无差别攻击，是真被气到了。","parentId":null,"children":[],"createdAt":1780917485612},"bookId":"3ef2c972-dba1-4872-8b43-3b40b0f05f0c","deletedAt":1780917494457},{"id":"31871ace-e216-44d1-9c6d-0cfc743917d0","type":"mindMapCard","item":{"id":"b3255e31-05b1-4c69-b19a-2197ca060add","title":"待到剑光散去，众人终于看清。","content":"待到剑光散去，众人终于看清。","parentId":null,"children":[],"createdAt":1780917485612},"bookId":"3ef2c972-dba1-4872-8b43-3b40b0f05f0c","deletedAt":1780917494457},{"id":"f93d2a05-1f6d-4707-a6eb-b64f2edef743","type":"mindMapCard","item":{"id":"37229be2-98a4-42a5-bfb1-ab7366e18fea","title":"李继挥剑挡住了那一双拳。","content":"李继挥剑挡住了那一双拳。","parentId":null,"children":[],"createdAt":1780917485612},"bookId":"3ef2c972-dba1-4872-8b43-3b40b0f05f0c","deletedAt":1780917494458},{"id":"a1c3139e-e9b9-488a-970d-0e0d7e00eab9","type":"mindMapCard","item":{"id":"20d0b36b-a07e-4278-b388-b43832bff582","title":"缘舜的拳头砸在剑身上，渗出血丝，那血顺着剑身，来到剑尖，最后","content":"缘舜的拳头砸在剑身上，渗出血丝，那血顺着剑身，来到剑尖，最后滴落在地。","parentId":null,"children":[],"createdAt":1780917485612},"bookId":"3ef2c972-dba1-4872-8b43-3b40b0f05f0c","deletedAt":1780917494458},{"id":"e750dfb3-d4b1-4305-a999-bd1f7402c353","type":"mindMapCard","item":{"id":"dceaf577-be6f-486a-8f9d-ad993e296db1","title":"“你..”","content":"“你..”","parentId":null,"children":[],"createdAt":1780917485612},"bookId":"3ef2c972-dba1-4872-8b43-3b40b0f05f0c","deletedAt":1780917494458},{"id":"61c9c844-9118-4c2e-bf27-b0a536b4f862","type":"mindMapCard","item":{"id":"32035cea-1bb8-4399-8d25-062e1c19c726","title":"缘舜的瞳孔因为震惊而缩小。他震惊，不止是因为李继竟然能在如此","content":"缘舜的瞳孔因为震惊而缩小。他震惊，不止是因为李继竟然能在如此之短的时间内，挡下这一招。更是因为，李继所释放出的威压，远远超出了自己的想象。他曾以为，自己与友人之间的差距，不过在努力而已。天赋一事，一直是几人之间闭口不谈的话题。于是为了追赶他们，缘舜日夜不休地精进武艺，一日不够便三日，三日不够便九日。","parentId":null,"children":[],"createdAt":1780917485612},"bookId":"3ef2c972-dba1-4872-8b43-3b40b0f05f0c","deletedAt":1780917494459},{"id":"9968b61c-4cc5-45cd-b973-19f74abf581f","type":"mindMapCard","item":{"id":"3fdee6de-cd78-413e-b162-0a538ab927f1","title":"林九霄笑他：只会练你那棍棒刀枪，到时别只长了技法，没长脑子。","content":"林九霄笑他：只会练你那棍棒刀枪，到时别只长了技法，没长脑子。","parentId":null,"children":[],"createdAt":1780917485612},"bookId":"3ef2c972-dba1-4872-8b43-3b40b0f05f0c","deletedAt":1780917494459},{"id":"3d77e6ad-1217-4968-bfd5-e4718973f5a7","type":"mindMapCard","item":{"id":"9bb79f3f-a6a2-4748-9315-a5569d6ede5e","title":"他不服气，长脑子，也不过是多读几本书，我有什么不行？","content":"他不服气，长脑子，也不过是多读几本书，我有什么不行？","parentId":null,"children":[],"createdAt":1780917485612},"bookId":"3ef2c972-dba1-4872-8b43-3b40b0f05f0c","deletedAt":1780917494459},{"id":"b9257bcf-dc63-4822-9809-163ae12fc9cc","type":"mindMapCard","item":{"id":"ac7a7b60-2385-40c2-ae61-62b4199128f9","title":"然而，然而。","content":"然而，然而。","parentId":null,"children":[],"createdAt":1780917485612},"bookId":"3ef2c972-dba1-4872-8b43-3b40b0f05f0c","deletedAt":1780917494460},{"id":"33074455-8379-4ca2-8271-b49bd02a31b3","type":"mindMapCard","item":{"id":"73ae8f21-012d-40ae-a173-28fdb410c5e2","title":"缘舜的眼泪掉了下来，和他的血一起，消失在地毯中。","content":"缘舜的眼泪掉了下来，和他的血一起，消失在地毯中。","parentId":null,"children":[],"createdAt":1780917485612},"bookId":"3ef2c972-dba1-4872-8b43-3b40b0f05f0c","deletedAt":1780917494460},{"id":"56ccbea6-270c-419d-9eac-9677072d2526","type":"mindMapCard","item":{"id":"5bbaee29-d503-4590-a423-d2874ce16c6b","title":"缘不名见他哭了，无奈道：“这搞得多难看...”","content":"缘不名见他哭了，无奈道：“这搞得多难看...”","parentId":null,"children":[],"createdAt":1780917485612},"bookId":"3ef2c972-dba1-4872-8b43-3b40b0f05f0c","deletedAt":1780917494460},{"id":"71e50c37-ebec-41d3-991a-f5320824ddfa","type":"mindMapCard","item":{"id":"426d97a1-8edd-461b-a0fc-287f8c6a9626","title":"事情到这还没结束。","content":"事情到这还没结束。","parentId":null,"children":[],"createdAt":1780917485615},"bookId":"3ef2c972-dba1-4872-8b43-3b40b0f05f0c","deletedAt":1780917494461},{"id":"f7456bfe-193a-41f7-98fd-bda5721fb504","type":"mindMapCard","item":{"id":"03dab85e-c7b2-441a-8a0f-1099c5381a9e","title":"常佑的长刀上泛起火焰，她的犬耳和尾巴也冒了出来，她气得直呲牙","content":"常佑的长刀上泛起火焰，她的犬耳和尾巴也冒了出来，她气得直呲牙。我都放你一马了，你居然敢搞偷袭？这么下三滥的手段，你居然敢用在我身上？还有这个叫李继的，当自己看不出来么，这一挡看似是要护住自己，其实是要护住那个缺心眼的呢！","parentId":null,"children":[],"createdAt":1780917485615},"bookId":"3ef2c972-dba1-4872-8b43-3b40b0f05f0c","deletedAt":1780917494462},{"id":"7aefb775-7a2d-40d7-ae46-831c93c1672b","type":"mindMapCard","item":{"id":"68fa13ef-406b-412d-8887-ac82b8ad7ad9","title":"你猜猜我会不会让你如愿？","content":"你猜猜我会不会让你如愿？","parentId":null,"children":[],"createdAt":1780917485615},"bookId":"3ef2c972-dba1-4872-8b43-3b40b0f05f0c","deletedAt":1780917494462},{"id":"d56d101d-c0b3-4101-a435-2bfabc7bc6e2","type":"mindMapCard","item":{"id":"6ec77e64-b257-4bba-a50c-1132933876fb","title":"“行啊，既然你都用尽全力出拳了，那我同为习武者，也不能怠慢了","content":"“行啊，既然你都用尽全力出拳了，那我同为习武者，也不能怠慢了你。你出全力，我也得出全力才是！”","parentId":null,"children":[],"createdAt":1780917485615},"bookId":"3ef2c972-dba1-4872-8b43-3b40b0f05f0c","deletedAt":1780917494462},{"id":"1975a8b7-e494-4e2a-9b10-253278fa05a1","type":"mindMapCard","item":{"id":"944c28c4-845c-40fb-b216-de5ff95846ba","title":"“吃我这刀！”","content":"“吃我这刀！”","parentId":null,"children":[],"createdAt":1780917485615},"bookId":"3ef2c972-dba1-4872-8b43-3b40b0f05f0c","deletedAt":1780917494462},{"id":"ef7f6b16-1c41-4635-8f18-9890922dbad2","type":"mindMapCard","item":{"id":"57c4a02c-9224-412a-8c26-3f97daad1eba","title":"第三章","content":"第三章","parentId":null,"children":[],"createdAt":1780917485615},"bookId":"3ef2c972-dba1-4872-8b43-3b40b0f05f0c","deletedAt":1780917494463},{"id":"77eeffb6-5d87-45b2-9c0b-afe8ebe90be5","type":"mindMapCard","item":{"id":"181b3e37-fff5-41b5-9561-60de149339c8","title":"李继退无可退，为了保住缘舜，选择正面接下这一刀。只听得“咣当","content":"李继退无可退，为了保住缘舜，选择正面接下这一刀。只听得“咣当”一声，刀剑相接，火花四溅，他的整条手臂都被震麻了。再定神一看，自己的剑上居然出现了肉眼可见的裂痕。他叫苦不迭：李返真啊李返真，你个逆徒，给我找了个活阎王回来。","parentId":null,"children":[],"createdAt":1780917485615},"bookId":"3ef2c972-dba1-4872-8b43-3b40b0f05f0c","deletedAt":1780917494463},{"id":"96e7f3f1-f9d4-4059-ab78-534edea1b319","type":"mindMapCard","item":{"id":"07799f29-74e3-4c78-a94f-0c5d4da2f9a6","title":"正当李继调转灵力，强行恢复知觉时，缘不名拍案而起，大骂：“你","content":"正当李继调转灵力，强行恢复知觉时，缘不名拍案而起，大骂：“你是个什么东西，想当着我的面动手杀了我哥？”","parentId":null,"children":[],"createdAt":1780917485615},"bookId":"3ef2c972-dba1-4872-8b43-3b40b0f05f0c","deletedAt":1780917494463},{"id":"0298694c-4eeb-49c2-9a50-77643a05c008","type":"mindMapCard","item":{"id":"73592d87-2e49-42dc-990c-2723807f1541","title":"李继觉得自己回去该吃多点胃药了。","content":"李继觉得自己回去该吃多点胃药了。","parentId":null,"children":[],"createdAt":1780917485615},"bookId":"3ef2c972-dba1-4872-8b43-3b40b0f05f0c","deletedAt":1780917494464},{"id":"3e26d33a-b2d2-48f2-8ac5-10a99bb44a4a","type":"mindMapCard","item":{"id":"ae87adc4-d89d-4e9d-8a75-1d1708a529b9","title":"缘不名愤怒至极，在他看来，李继挡下哥哥那一拳，已经表明态度，","content":"缘不名愤怒至极，在他看来，李继挡下哥哥那一拳，已经表明态度，他们根本无意要伤常佑。反而是常佑，多次羞辱他哥不说，现在还想当着他们三人的面将缘舜处决。他不想再忍，不能再忍。缘不名掏出长鞭，浑厚的水汽同灵力附之其上，男人的轻功已臻化境，只一瞬便冲到了常佑面前。","parentId":null,"children":[],"createdAt":1780917485615},"bookId":"3ef2c972-dba1-4872-8b43-3b40b0f05f0c","deletedAt":1780917494465},{"id":"5f824315-7192-401c-8f78-06a787370c09","type":"mindMapCard","item":{"id":"a0a9f14d-16ba-4212-94c6-5219b926a611","title":"缘不名面对这个刚刚将李继、缘舜一招制服的常佑，没有丝毫退缩。","content":"缘不名面对这个刚刚将李继、缘舜一招制服的常佑，没有丝毫退缩。","parentId":null,"children":[],"createdAt":1780917485615},"bookId":"3ef2c972-dba1-4872-8b43-3b40b0f05f0c","deletedAt":1780917494465},{"id":"7364d1f2-64a2-44a2-834f-ba55705632f4","type":"mindMapCard","item":{"id":"b37abcd6-9b01-4cc9-a2e7-6960e1b7fbde","title":"他挥出了第一鞭。","content":"他挥出了第一鞭。","parentId":null,"children":[],"createdAt":1780917485616},"bookId":"3ef2c972-dba1-4872-8b43-3b40b0f05f0c","deletedAt":1780917494466},{"id":"a3c062d2-5b94-40ca-a9be-5659f12331d7","type":"mindMapCard","item":{"id":"37f05dac-aa2e-4512-99a9-b7f8bab9f004","title":"快，极快，这一鞭打出时的破空声凌厉而凶狠，缘不名似乎势要使出","content":"快，极快，这一鞭打出时的破空声凌厉而凶狠，缘不名似乎势要使出毕生绝学，替缘舜洗刷耻辱。","parentId":null,"children":[],"createdAt":1780917485616},"bookId":"3ef2c972-dba1-4872-8b43-3b40b0f05f0c","deletedAt":1780917494466},{"id":"2a3e2f03-5f4b-43a8-a563-1b2f31c3e7b5","type":"mindMapCard","item":{"id":"081896d2-f01c-406f-8374-0b7015a5e9df","title":"常佑闪身避开长鞭，凭借直觉，向前送出一刀。她将天火收回自身，","content":"常佑闪身避开长鞭，凭借直觉，向前送出一刀。她将天火收回自身，形成一层薄膜，防御可能的攻击，常佑料定这人不敢用长鞭接触天火，更别说把自己捆住——那你这武器也别想要了！","parentId":null,"children":[],"createdAt":1780917485616},"bookId":"3ef2c972-dba1-4872-8b43-3b40b0f05f0c","deletedAt":1780917494466},{"id":"59335038-a6b5-4b45-ac65-850394e614d1","type":"mindMapCard","item":{"id":"81ea9cd7-a92a-43ee-9b47-9ea154b0b847","title":"可当她的刀尖碰到长鞭时，常佑立刻意识到自己上当了。这人压根是","content":"可当她的刀尖碰到长鞭时，常佑立刻意识到自己上当了。这人压根是在虚张声势，这一鞭压根不是冲着她人来的，是冲着刀来的。长鞭同蛇一般将长刀紧紧锁死，自己此时若不将刀放开，背后���两人说不准什么时���就要���殴她���。","parentId":null,"children":[],"createdAt":1780917485616},"bookId":"3ef2c972-dba1-4872-8b43-3b40b0f05f0c","deletedAt":1780917494467},{"id":"102b9307-0fe4-44ba-a80d-00dcd4036241","type":"mindMapCard","item":{"id":"61961f90-0d42-453c-a840-b8c86b30258d","title":"没有任何犹豫，常佑放开自己的刀，任它被长鞭甩进大殿的柱子上。","content":"没有任何犹豫，常佑放开自己的刀，任它被长鞭甩进大殿的柱子上。","parentId":null,"children":[],"createdAt":1780917485616},"bookId":"3ef2c972-dba1-4872-8b43-3b40b0f05f0c","deletedAt":1780917494467},{"id":"8915f3a9-7c5c-4cd1-a70b-4af085f820c6","type":"mindMapCard","item":{"id":"1426f808-2a7b-4de6-8c0c-6d2e299f1631","title":"其实想要去取也不是很难。常佑抬头看了看，顺便躲过第二鞭，但是","content":"其实想要去取也不是很难。常佑抬头看了看，顺便躲过第二鞭，但是她已经失去耐心。","parentId":null,"children":[],"createdAt":1780917485616},"bookId":"3ef2c972-dba1-4872-8b43-3b40b0f05f0c","deletedAt":1780917494467},{"id":"eed64977-a588-4b4b-b6c6-d9651ee31cb4","type":"mindMapCard","item":{"id":"46b9ddc1-eac9-433a-9c97-f43977d2a421","title":"这个拿鞭子的睁眼瞎说自己要杀人，似乎这时那边拿剑的就消失了。","content":"这个拿鞭子的睁眼瞎说自己要杀人，似乎这时那边拿剑的就消失了。她还能不知道李继要挡吗？不是那个缘舜没了武器还想偷袭，一点也不讲武德，自己才出手吗？还有就是那个就爱说风凉话，不敢打架的，又开始泡茶喝了，他嘴这么馋，怎么就停不下来呢？","parentId":null,"children":[],"createdAt":1780917485616},"bookId":"3ef2c972-dba1-4872-8b43-3b40b0f05f0c","deletedAt":1780917494468},{"id":"c2680fc6-4b9e-4201-b6c3-de56f12a6693","type":"mindMapCard","item":{"id":"9c873620-b375-4a9b-b342-b9c5a373f329","title":"自己的回击就这样被解读成了别有用心，还有人类能和我交流不？","content":"自己的回击就这样被解读成了别有用心，还有人类能和我交流不？","parentId":null,"children":[],"createdAt":1780917485616},"bookId":"3ef2c972-dba1-4872-8b43-3b40b0f05f0c","deletedAt":1780917494468},{"id":"e4ccb335-edb4-48eb-b03a-cfa4333fdfc5","type":"mindMapCard","item":{"id":"b6f1e5ad-8744-451f-a94d-0122bae9965c","title":"李返真见状不妙，反身就跑，想去找救兵。一边跑，一边苦哈哈的想","content":"李返真见状不妙，���身就跑，想去找救兵。一边跑，一边苦哈哈的想：宗里最强的辈分最大的都在这了，他还能怎么办，不去找人来，难道他也上去打常佑吗？用脚指头想也知道，赢面为零。但是他现在还能去找谁啊？哪怕他有搬天兵的能力，那人家常佑都说了，她天上下来的，他们说不定还是一伙的呢。","parentId":null,"children":[],"createdAt":1780917485616},"bookId":"3ef2c972-dba1-4872-8b43-3b40b0f05f0c","deletedAt":1780917494469},{"id":"53581e08-038e-49b3-ab55-232ab637f998","type":"mindMapCard","item":{"id":"6bd97d6b-04be-42b2-bd62-544256407cfd","title":"怎么办？李返真越跑越没方向，越跑越迷茫。风吹过他的脸颊，思绪","content":"怎么办？李返真越跑越没方向，越跑越迷茫。风吹过他的脸颊，思绪被揉成一团。不远处，大殿的灵力场波动得厉害，他们肯定还在打。","parentId":null,"children":[],"createdAt":1780917485616},"bookId":"3ef2c972-dba1-4872-8b43-3b40b0f05f0c","deletedAt":1780917494469},{"id":"3664d22b-2ae7-4361-9293-fcfbdb764fca","type":"mindMapCard","item":{"id":"df679379-5365-4490-8e0b-1d66e8502c1e","title":"我不能就这么什么也不干，还待在原地，给师父他们添乱。","content":"我不能就这么什么也不干，还待在原地，给师父他们添乱。","parentId":null,"children":[],"createdAt":1780917485616},"bookId":"3ef2c972-dba1-4872-8b43-3b40b0f05f0c","deletedAt":1780917494469},{"id":"a1fcc0b3-9663-44fe-b1fb-fc8dbe4b5469","type":"mindMapCard","item":{"id":"258f0c64-1fad-4afc-b2f4-7d4b6d0a743b","title":"但我还能做些什么？","content":"但我还能做些什么？","parentId":null,"children":[],"createdAt":1780917485616},"bookId":"3ef2c972-dba1-4872-8b43-3b40b0f05f0c","deletedAt":1780917494470},{"id":"a2b3aae3-29a8-4c01-aa7a-c2f57a6051ea","type":"mindMapCard","item":{"id":"050cdfbb-c821-44ef-8def-116fd9d9e2fa","title":"我还能再做些什么呢？","content":"我还能再做些什么呢？","parentId":null,"children":[],"createdAt":1780917485616},"bookId":"3ef2c972-dba1-4872-8b43-3b40b0f05f0c","deletedAt":1780917494470},{"id":"5bca8ed5-dbf9-4828-bbaf-8a7d28284cc1","type":"mindMapCard","item":{"id":"e2dddc56-530c-4b80-a2e1-b064f724a834","title":"最后，他在习武场上停了下来。这是李返真平日最为熟悉的地方，也","content":"最后，他在习武场上停了下来。这是李返真平日最为熟悉的地方，也是他与同辈们切磋武艺的地方。","parentId":null,"children":[],"createdAt":1780917485616},"bookId":"3ef2c972-dba1-4872-8b43-3b40b0f05f0c","deletedAt":1780917494470},{"id":"40769796-3cf6-4870-8a6e-36778e99d188","type":"mindMapCard","item":{"id":"24dad4f2-82f9-4d2f-9ee7-2640d0317e3b","title":"青妙音看见李返真，有些意外：“你怎么就出来了？我正要去给你们","content":"青妙音看见李返真，有些意外：“你怎么就出来了？我正要去给你们送菜呢。”","parentId":null,"children":[],"createdAt":1780917485616},"bookId":"3ef2c972-dba1-4872-8b43-3b40b0f05f0c","deletedAt":1780917494471},{"id":"d2aab2a2-d078-4561-88db-4b1ad8dfdda4","type":"mindMapCard","item":{"id":"268b4619-dd5e-41ef-8e56-25a63b1ed30d","title":"她晃了晃手上的餐盒，这餐盒可方便，看着小小的，其实类似芥子袋","content":"她晃了晃手上的餐盒，这餐盒可方便，看着小小的，其实类似芥子袋，藏了不少好吃的。今个难得他们一聚，师父可是掏了不少钱给厨房。青妙音想着自己到时也要去，还拜托厨房拿了两罐酒进里头。上面装的菜肴，中间是酒，最底下呢，是她最近练好的丹药。正好，给师父他们补一补。","parentId":null,"children":[],"createdAt":1780917485616},"bookId":"3ef2c972-dba1-4872-8b43-3b40b0f05f0c","deletedAt":1780917494471},{"id":"67014f6b-3d31-4839-b281-753a5b310869","type":"mindMapCard","item":{"id":"de06a255-28d1-44aa-882d-be7869dfb803","title":"“别去。师妹，千万别去！”","content":"“别去。师妹，千万别去！”","parentId":null,"children":[],"createdAt":1780917485616},"bookId":"3ef2c972-dba1-4872-8b43-3b40b0f05f0c","deletedAt":1780917494471},{"id":"252f3d5b-2940-4af9-864b-abe76dd5bc6f","type":"mindMapCard","item":{"id":"db49bd24-cdb3-4145-96ba-90a093a049eb","title":"李返真看见熟悉的脸，终于回过神来，恐惧缓缓爬上他的脊柱。他捏","content":"李返真看见熟悉的脸，终于回过神来，恐惧缓缓爬上他的脊柱。他捏紧拳头，牙齿打颤：“师妹，那边发生大事了。”","parentId":null,"children":[],"createdAt":1780917485616},"bookId":"3ef2c972-dba1-4872-8b43-3b40b0f05f0c","deletedAt":1780917494471},{"id":"6bef4245-2a4d-4df2-9337-9b874e2dc1c8","type":"mindMapCard","item":{"id":"3647def3-b675-4137-9776-9eb900f53ab9","title":"“什么事？你怎么吓成这样。”","content":"“什么事？你怎么吓成这样。”","parentId":null,"children":[],"createdAt":1780917485616},"bookId":"3ef2c972-dba1-4872-8b43-3b40b0f05f0c","deletedAt":1780917494472},{"id":"a5b3e1a0-0f52-442b-8a43-05ce46aebd3b","type":"mindMapCard","item":{"id":"68fd8344-efb3-4c69-ba5f-b8715716f8a1","title":"青妙音上下扫他一眼，十分奇怪：“哎，你刚刚回来的时候不是还抱","content":"青妙音上下扫他一眼，十分奇怪：“哎，你刚刚回来的时候不是还抱着条小狗吗？你要不养，就交给我，最近山上犯鼠患，正好厨房和药房连着，我把它放那去。”","parentId":null,"children":[],"createdAt":1780917485616},"bookId":"3ef2c972-dba1-4872-8b43-3b40b0f05f0c","deletedAt":1780917494472},{"id":"d7607869-a59a-405f-81a2-68344d9f6688","type":"mindMapCard","item":{"id":"4a54a798-2b0d-49e9-859b-bbd4faf55e26","title":"“就是，那个犬妖闹出来的事！”","content":"“就是，那个犬妖闹出来的事！”","parentId":null,"children":[],"createdAt":1780917485616},"bookId":"3ef2c972-dba1-4872-8b43-3b40b0f05f0c","deletedAt":1780917494473},{"id":"06da216f-c9fc-4e5b-90d7-674530f7d3ad","type":"mindMapCard","item":{"id":"bd6a311b-5bb7-4a1b-b38c-6c0966b65f56","title":"李返真急得直用手比划，不知怎么拼凑语言才好，这事实在太惊世骇","content":"李返真急得直用手比划，不知怎么拼凑语言才好，这事实在太惊世骇俗，说出去恐怕都没人信。","parentId":null,"children":[],"createdAt":1780917485616},"bookId":"3ef2c972-dba1-4872-8b43-3b40b0f05f0c","deletedAt":1780917494473},{"id":"323ffd99-6b77-4da5-868d-04b7c552873b","type":"mindMapCard","item":{"id":"e42feea7-effe-466f-968a-98fc393eec3a","title":"“你慢慢说啊，什么事？”","content":"“你慢慢说啊，什么事？”","parentId":null,"children":[],"createdAt":1780917485616},"bookId":"3ef2c972-dba1-4872-8b43-3b40b0f05f0c","deletedAt":1780917494473},{"id":"f2c21096-4580-4bf3-b770-ced61ab8a391","type":"mindMapCard","item":{"id":"b96dde79-2f97-4959-b60a-115b1676360a","title":"青妙音感到莫名其妙，她没能从李返真的肢体语言里解读出他的焦躁","content":"青妙音感到莫名其妙，她没能从李返真的肢体语言里解读出他的焦躁，她觉得这症状更像是吃错了丹药。不会是手底下哪个小孩往李返真的药葫芦里倒了加料的丸子吧？看他今天这抽抽的劲，真受不了。","parentId":null,"children":[],"createdAt":1780917485616},"bookId":"3ef2c972-dba1-4872-8b43-3b40b0f05f0c","deletedAt":1780917494473},{"id":"82d0c0d1-cc8e-4c6d-9542-86d3a4920422","type":"mindMapCard","item":{"id":"fbe29191-befa-4127-8def-c3331ff5649a","title":"“那犬妖一口气把师父和缘大哥给打倒了现在还要揍缘二哥！”","content":"“那犬妖一口气把师父和缘大哥给打倒了现在还要揍缘二哥！”","parentId":null,"children":[],"createdAt":1780917485616},"bookId":"3ef2c972-dba1-4872-8b43-3b40b0f05f0c","deletedAt":1780917494474},{"id":"aabcb676-244c-4671-be47-9c99c2a5235b","type":"mindMapCard","item":{"id":"6d1dc1eb-3d98-406e-baee-3742e05e3f97","title":"青妙音：？","content":"青妙音：？","parentId":null,"children":[],"createdAt":1780917485616},"bookId":"3ef2c972-dba1-4872-8b43-3b40b0f05f0c","deletedAt":1780917494474},{"id":"1993a962-3401-4218-8748-77e408f59e72","type":"mindMapCard","item":{"id":"f6dd1eaf-74d1-40d6-a732-8e99268f1d8c","title":"她现在相信师兄吃错药了。","content":"她现在相信师兄吃错药了。","parentId":null,"children":[],"createdAt":1780917485616},"bookId":"3ef2c972-dba1-4872-8b43-3b40b0f05f0c","deletedAt":1780917494474},{"id":"83fb8882-51d6-4924-b164-886ce605cd4e","type":"mindMapCard","item":{"id":"b076f229-1ed8-4cb7-b39f-673a3f04b95f","title":"白日做梦也做不出那么荒谬的剧情，他的想象力不足以支撑这样的梦","content":"白日做梦也做不出那么荒谬的剧情，他的想象力不足以支撑这样的梦。只可能是外力作用了。","parentId":null,"children":[],"createdAt":1780917485616},"bookId":"3ef2c972-dba1-4872-8b43-3b40b0f05f0c","deletedAt":1780917494475},{"id":"769f7e1d-2506-4a54-a2c3-085349a18741","type":"mindMapCard","item":{"id":"e58135fd-85cb-4ef9-b0f3-80ad7a2c5426","title":"青妙音关切地伸出手，要去探李返真的额头：“你是不是又被整了？","content":"青妙音关切地伸出手，要去探李返真的额头：“你是不是又被整了？”","parentId":null,"children":[],"createdAt":1780917485616},"bookId":"3ef2c972-dba1-4872-8b43-3b40b0f05f0c","deletedAt":1780917494475},{"id":"0f11b2e6-5e06-451f-bc48-b3ecbe908456","type":"mindMapCard","item":{"id":"8d81f105-8a3b-41de-822e-1a482dfe0a12","title":"李返真的表情要哭不哭，要笑不笑：“我情愿我是被整了。谁整我都","content":"李返真的表情要哭不哭，要笑不笑：“我情愿我是被整了。谁整我都好，别整我师父。”","parentId":null,"children":[],"createdAt":1780917485616},"bookId":"3ef2c972-dba1-4872-8b43-3b40b0f05f0c","deletedAt":1780917494476},{"id":"f0a07535-d47b-4a86-87a6-2774c86d7e0e","type":"mindMapCard","item":{"id":"d831b051-50d9-44c0-b0de-6a273cdd4b3d","title":"她转而去捏李返真的脖子，探他的脉搏，这也很正常，似乎真没中毒","content":"她转而去捏李返真的脖子，探他的脉搏，这也很正常，似乎真没中毒。","parentId":null,"children":[],"createdAt":1780917485616},"bookId":"3ef2c972-dba1-4872-8b43-3b40b0f05f0c","deletedAt":1780917494476},{"id":"cf3079f3-f873-4cd6-98a4-eaad79114d85","type":"mindMapCard","item":{"id":"f60fe441-744d-429b-819c-501f09b5d301","ti