{
  "name": "novel-writing-assistant",
  "version": "1.0.0",
  "description": "小说创作助手 - 喵~ 思维导图 + 灵感卡片 + 扭蛋机 + 书籍目录",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite --open",
    "build": "vite build",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "start": "electron ."
  },
  "dependencies": {
    "diff": "^5.1.0",
    "mammoth": "^1.12.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.0",
    "concurrently": "^8.2.0",
    "electron": "^22.3.27",
    "vite": "^5.0.0",
    "wait-on": "^7.2.0"
  }
}
